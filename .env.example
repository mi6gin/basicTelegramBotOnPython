# Токен Telegram-бота, полученный от @BotFather
BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"

# Список Telegram ID администраторов через запятую (например: 123456789,987654321)
ADMIN_IDS="123456789"

# URL подключения к базе данных. По умолчанию используется асинхронный SQLite (aiosqlite)
DB_URL="sqlite+aiosqlite:///nihao_chan.db"

# Задержка между отправкой сообщений для антифлуда в секундах
THROTTLING_DELAY=0.8
